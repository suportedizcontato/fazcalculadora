{
  "buildCommand": "npx --yes pnpm@10.32.1 install && npx pnpm@10.32.1 --filter fazaconta exec vite build --config vite.config.local.ts",
  "outputDirectory": "fazaconta/dist/public",
  "installCommand": "echo 'install handled by buildCommand'",
  "framework": null,
  "env": {
    "CYPRESS_INSTALL_BINARY": "0"
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fazacontaonline.com" }],
      "destination": "https://www.fazacontaonline.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path+/",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
